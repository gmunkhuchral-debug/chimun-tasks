    },
    {
      "parameters": {
        "jsCode": "// Validate + prep file from base64 body.\n// Expected body: { filename, contentType, base64, request_id, kind: 'purchase'|'payment'|'completion' }\nconst body = $input.first().json.body || {};\nif (!body.base64 || !body.filename) {\n  throw new Error('base64 эсвэл filename талбар дутуу');\n}\nconst kind = (body.kind || 'purchase').toLowerCase();\nconst safeKind = ['purchase','payment','completion'].includes(kind) ? kind : 'purchase';\n// Folder routing — kind-ээс шалтгаалаад зөв фолдер сонгоно\nconst FOLDER = {\n  purchase:   '1JccijKlhJr8q9D8jF7GZb5mtzSMUFGOx',\n  payment:    '1JccijKlhJr8q9D8jF7GZb5mtzSMUFGOx',\n  completion: '10jy-UdllNNS2zbvx945OzMntEtis5gEH',\n};\nconst folderId = FOLDER[safeKind] || FOLDER.purchase;\nconst requestId = (body.request_id || 'no-id').replace(/[^a-zA-Z0-9_-]/g,'');\nconst dateStr = new Date().toISOString().slice(0,10);\nconst ext = (body.filename.split('.').pop() || 'jpg').toLowerCase();\nconst finalName = `${dateStr}_${requestId}_${safeKind}.${ext}`;\nconst rawB64 = body.base64.replace(/^data:[^;]+;base64,/,'');\nconst buf = Buffer.from(rawB64, 'base64');\nreturn [{\n  json: {\n    filename: finalName,\n    contentType: body.contentType || 'application/octet-stream',\n    size: buf.length,\n    request_id: requestId,\n    kind: safeKind,\n    folderId,\n  },\n  binary: {\n    data: {\n      data: rawB64,\n      mimeType: body.contentType || 'application/octet-stream',\n      fileName: finalName\n    }\n  }\n}];"
      },
